import_c_om "SDL2/SDL.h" as sdl2

class main
    fun start()
        zone "sdl-events":
            let ok = sdl2.init(sdl2.INIT_VIDEO)
            let window = sdl2.create_window("Snask SDL2 Events", 0, 0, 320, 240, sdl2.WINDOW_HIDDEN)
            let event_type = sdl2.poll_event()
            print(event_type)
            sdl2.quit()
