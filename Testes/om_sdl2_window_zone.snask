import_c_om "SDL2/SDL.h" as sdl2

class main
    fun start()
        zone "sdl-window":
            let ok = sdl2.init(sdl2.INIT_VIDEO)
            let window = sdl2.create_window("Snask SDL2 Auto-OM", 0, 0, 320, 240, sdl2.WINDOW_HIDDEN)
            sdl2.delay(50)
            print("SDL2 window allocated under OM")
            sdl2.quit()
