// Snask OM & Quantum Value - Mass Test

class Player
    let id = 0;
    let name = "Hero";

class Enemy
    let power = 100;

@unsafe fun direct_memory_access()
    print("WARNING: Entering unsafe territory");
    // Aqui o compilador gera marcadores de risco
    return nil;

class main
    fun start()
        print("--- STARTING QUANTUM OM TEST ---");

        // 1. Teste de Tipos (NaN-Boxing)
        let a = 10.5;
        let b = 20;
        let c = a + b;
        let d = true;
        let e = nil;
        print("Arithmetic (10.5 + 20):", c);
        print("Boolean value:", d);
        print("Nil value:", e);

        // 2. Estratégias de Alocação (OM)
        let p1 = new stack Player();
        let p2 = new heap Player();
        
        zone "dungeon_level"
            print("Inside Dungeon Zone...");
            let e1 = new arena Enemy();
            let e2 = new arena Enemy();
            
            // 3. Emaranhamento (Lifecycle Bond)
            entangle e1 with p1;
            print("Enemy e1 entangled with Player p1");

        // 4. Promoção (Memory Migration)
        print("Promoting p1 to heap...");
        promote p1 to heap;

        // 5. Escopos Nomeados
        scope temporary_fx
            print("Inside temporary scope");
            let fx = new stack Player();
        
        // 6. Blocos @unsafe
        @unsafe
            print("Executing unsafe block...");
            direct_memory_access();

        print("--- TEST COMPLETE ---");
