class Point
    let x = 0.0;
    fun init()
        return nil;

class main
    fun start()
        print("Iniciando benchmark Alloc Only (Snask Arena)...");
        let start = time();
        
        zone "fast"
            mut i = 0;
            while i < 1000000
                new arena Point();
                i = i + 1;

        let end = time();
        print("Tempo Snask (Arena Alloc Only): ", end - start, " s");
