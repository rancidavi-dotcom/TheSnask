class Point
    let x = 0.0;
    let y = 0.0;
    let z = 0.0;

    fun init(vx, vy, vz)
        self.x = vx;
        self.y = vy;
        self.z = vz;
        return nil;

class main
    fun start()
        print("Iniciando benchmark Snask (Manual @unsafe + free)...");
        let start = time();
        mut total = 0.0;
        
        mut i = 0;
        while i < 5000000
            @unsafe
                let p = new heap Point(1.0, 2.0, 3.0);
                total = total + p.x + p.y + p.z;
                // 'free' mapeia para s_free_obj que limpa SnaskObject no runtime
                free(p);
            i = i + 1;

        let end = time();
        print("Resultado Snask: ", total);
        print("Tempo Snask (Manual): ", end - start, " s");
