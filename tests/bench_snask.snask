class Point
    let x = 0.0;
    let y = 0.0;
    let z = 0.0;

    fun init(vx, vy, vz)
        self.x = vx;
        self.y = vy;
        self.z = vz;
        return nil;

class main
    fun start()
        print("Iniciando benchmark Snask (OM Stack Allocation)...");
        let start = time();
        mut total = 0.0;
        
        mut i = 0;
        while i < 1000000
            // Em Snask, 'new stack' aloca na stack do LLVM
            let p = new stack Point(1.0, 2.0, 3.0);
            total = total + p.x + p.y + p.z;
            i = i + 1;

        let end = time();
        print("Resultado Snask: ", total);
        print("Tempo Snask (OM): ", end - start, " s");
