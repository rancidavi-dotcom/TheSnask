class main {
    fun start() {
        let x = 10
        mut y = 20; // com ponto e virgula ainda funciona
        
        if x < y {
            print("X é menor que Y\n")
        } else {
            print("X não é menor que Y\n")
        }

        mut i = 0
        while i < 3 {
            print("Loop: ", i, "\n")
            i = i + 1
        }
    }
}
