class main {
    fun meu_ponto_de_entrada() {
        let nome = "Davidev"
        let pontos = 100
        
        // String Interpolation
        print("Olá, {nome}! Você tem {pontos} pontos.\n")

        // Trailing Commas e interpolação de lista
        let lista = [
            "maçã",
            "banana",
            "laranja",
        ]
        
        print("Sua lista tem {len(lista)} itens.\n")
    }
}
